# =====================================================
# 환경변수 예시 파일 — GitHub에 커밋되는 템플릿
# 실제 값을 채워서 .env 파일로 복사해 사용할 것
# cp .env.example .env
# =====================================================

# ── MySQL ──────────────────────────────────────────
MYSQL_DATABASE=restaurant_db
MYSQL_ROOT_PASSWORD=your_root_password_here

# ── Spring Boot ────────────────────────────────────
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=your_root_password_here
